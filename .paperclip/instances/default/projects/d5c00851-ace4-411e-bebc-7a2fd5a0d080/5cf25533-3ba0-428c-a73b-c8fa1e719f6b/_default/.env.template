# Paperclip Installer — environment template
# Copy to .env and fill in values before running: docker compose up -d

# Host-side port for Paperclip (container always listens on 3100 internally)
PAPERCLIP_PORT=3100

# Auth secret — REQUIRED; generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=  # generate via: openssl rand -hex 32

# Public URL used in OAuth callbacks, agent links, and email
# Update this to your Tailscale Funnel URL or NordVPN Meshnet address after setup
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# Internal server bind settings (do not change for local installs)
HOST=0.0.0.0
PORT=3100

# Paperclip data directory inside the container (matches the volume mount)
PAPERCLIP_HOME=/paperclip

# Deployment settings (do not change for single-user local installs)
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# Optional: AI provider keys (only needed for openclaw_gateway / native provider agents)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
